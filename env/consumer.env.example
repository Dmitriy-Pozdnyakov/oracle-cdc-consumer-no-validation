# =========================
# Kafka connection
# =========================
KAFKA_BROKER=host.docker.internal:19092,host.docker.internal:19093,host.docker.internal:19094
KAFKA_GROUP_ID=oracle-cdc-consumer-no-validation
KAFKA_CLIENT_ID=oracle-cdc-consumer-no-validation
KAFKA_SECURITY_PROTOCOL=SASL_SSL
SSL_CAFILE=/certs/ca.crt
SSL_CHECK_HOSTNAME=false
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=kafka_user
KAFKA_SASL_PASSWORD=change_me_kafka_password

# =========================
# Topic subscription (topic-per-table only)
# =========================
# Regex subscription to all per-table topics, for example:
# cdc.raw.abs.hr.employees
TOPIC_REGEX=^cdc\.raw\.abs\.[^.]+\.[^.]+$
AUTO_OFFSET_RESET=earliest

# =========================
# Oneshot runtime
# =========================
POLL_TIMEOUT_SEC=1.0
MAX_MESSAGES=500
MAX_EMPTY_POLLS=15
# Sink mode:
# - csv:   write processed events into CSV file (Postgres imitation)
# - postgres: write processed events into Postgres stage table
SINK_TYPE=csv
CSV_SINK_PATH=/state/postgres_sink_stub.csv
VERBOSE=true

# =========================
# Postgres sink (used when SINK_TYPE=postgres)
# =========================
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DATABASE=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_SCHEMA=public
POSTGRES_TABLE=cdc_events
POSTGRES_SSLMODE=prefer
POSTGRES_CONNECT_TIMEOUT_SEC=10
POSTGRES_APPLICATION_NAME=oracle-cdc-consumer-no-validation
POSTGRES_AUTO_CREATE_TABLE=true

# =========================
# Apply (stage -> main)
# =========================
# Режимы:
# - simulate: не пишет в main-таблицу, только аудирует и меняет stage-статус.
# - real: выполняет реальный upsert/delete в target-таблицы Postgres.
APPLY_MODE=simulate
# Размер батча claim из stage.
APPLY_BATCH_SIZE=200
# Максимум stage-событий за один oneshot запуск apply.
APPLY_MAX_ROWS=5000
# CSV-аудит действий apply (upsert/hard_delete).
APPLY_SIMULATION_CSV_PATH=/state/apply_simulation.csv
# Если пусто, target schema берется из source_schema.
# Если задано, все изменения применяются в указанную schema.
APPLY_TARGET_SCHEMA=
# Префикс именованного PK constraint для auto-resolve PK колонок в real apply.
# Полный шаблон: <prefix><schema>_<table>, например cdc_pkey_hr_employees.
APPLY_PK_CONSTRAINT_PREFIX=cdc_pkey_
# Опционально: список PK-колонок через запятую для real apply.
# Используйте, если key-json не содержит бизнес-PK (например содержит только transport metadata).
# Пример: APPLY_PK_COLUMNS=ID
APPLY_PK_COLUMNS=

# =========================
# Bad message policy
# =========================
# strict: fail-fast (default)
# skip: log + commit offset
# dlq: write original bytes to DLQ + commit offset
BAD_MESSAGE_POLICY=strict
DLQ_TOPIC=oracle.cdc.bad
DLQ_FLUSH_TIMEOUT_SEC=10
