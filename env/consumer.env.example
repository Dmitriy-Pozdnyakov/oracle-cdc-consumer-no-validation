# =========================
# Kafka connection
# =========================
KAFKA_BROKER=host.docker.internal:19092,host.docker.internal:19093,host.docker.internal:19094
KAFKA_GROUP_ID=oracle-cdc-consumer-no-validation
KAFKA_CLIENT_ID=oracle-cdc-consumer-no-validation
KAFKA_SECURITY_PROTOCOL=SASL_SSL
SSL_CAFILE=/certs/ca.crt
SSL_CHECK_HOSTNAME=false
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=kafka_user
KAFKA_SASL_PASSWORD=change_me_kafka_password

# =========================
# Topic subscription (topic-per-table only)
# =========================
# Regex subscription to all per-table topics, for example:
# oracle.cdc.hr.employees
TOPIC_REGEX=^oracle\\.cdc\\..+\\..+$
AUTO_OFFSET_RESET=earliest

# =========================
# Oneshot runtime
# =========================
POLL_TIMEOUT_SEC=1.0
MAX_MESSAGES=500
MAX_EMPTY_POLLS=15
# Postgres sink stub:
# - true: after successful parse, write message into CSV (as DB write imitation)
# - false: skip CSV write step
POSTGRES_STUB_ENABLED=true
POSTGRES_STUB_CSV_PATH=/state/postgres_sink_stub.csv
VERBOSE=true

# =========================
# Bad message policy
# =========================
# strict: fail-fast (default)
# skip: log + commit offset
# dlq: write original bytes to DLQ + commit offset
BAD_MESSAGE_POLICY=strict
DLQ_TOPIC=oracle.cdc.bad
DLQ_FLUSH_TIMEOUT_SEC=10
